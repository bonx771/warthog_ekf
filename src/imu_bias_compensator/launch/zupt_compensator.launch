<!-- zupt_compensator.launch
     Main launch file for normal operation.
     Loads calibrated bias and runs online ZUPT compensation.

     Usage:
       roslaunch imu_bias_compensator zupt_compensator.launch
       roslaunch imu_bias_compensator zupt_compensator.launch use_odom:=false
-->
<launch>
  <arg name="imu_topic"             default="/imu/data_raw"/>
  <arg name="odom_topic"            default="/warthog_velocity_controller/odom"/>
  <arg name="use_odom"              default="true"/>
  <arg name="zero_gyro_when_static" default="true"/>
  <arg name="alpha"                 default="0.01"/>

  <node pkg="imu_bias_compensator"
        type="zupt_compensator.py"
        name="zupt_compensator"
        output="screen">

    <!-- Load default params then allow overrides -->
    <rosparam file="$(find imu_bias_compensator)/config/params.yaml"
              command="load"/>

    <!-- Load calibrated bias (auto-generated by calibrate.launch) -->
    <rosparam file="$(find imu_bias_compensator)/config/gyro_bias.yaml"
              command="load"/>

    <!-- CLI overrides -->
    <param name="imu_topic"             value="$(arg imu_topic)"/>
    <param name="odom_topic"            value="$(arg odom_topic)"/>
    <param name="use_odom"              value="$(arg use_odom)"/>
    <param name="zero_gyro_when_static" value="$(arg zero_gyro_when_static)"/>
    <param name="alpha"                 value="$(arg alpha)"/>
    <param name="bias_file"
           value="$(find imu_bias_compensator)/config/gyro_bias.yaml"/>
  </node>
</launch>
