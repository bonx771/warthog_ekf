<?xml version="1.0"?>
<launch>

  <node pkg="outdoor_waypoint_nav" type="imu_covariance_relay.py" name="imu_covariance_relay" output="screen">
    <param name="input_topic" value="/imu/data_nomag" />
    <param name="output_topic" value="/imu/data_covariance" />
    <rosparam param="orientation_diag">[0.5, 0.5, 0.5]</rosparam>
    <rosparam param="angular_velocity_diag">[0.05, 0.05, 0.00002]</rosparam>
    <rosparam param="linear_acceleration_diag">[0.1, 0.1, 0.1]</rosparam>
  </node>

  <node pkg="outdoor_waypoint_nav" type="imu_covariance_log.py" name="imu_covariance_log" output="screen">
    <remap from="imu/data" to="/imu/data_covariance" />
    <param name="log_rate_hz" value="10.0" />
  </node>

  <!--node pkg="tf" type="static_transform_publisher" name="imu_broadcaster" args="0 0.17 0.07 3.14159 0 0 base_link imu_link 100" /--> 


</launch>
