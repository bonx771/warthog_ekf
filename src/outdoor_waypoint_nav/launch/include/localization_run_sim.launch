<?xml version="1.0"?>
<launch>

  <group ns="/outdoor_waypoint_nav">
    <rosparam command="load" file="$(find outdoor_waypoint_nav)/params/ekf_params_sim.yaml" />
    <rosparam command="load" file="$(find outdoor_waypoint_nav)/params/navsat_params_sim.yaml" />

    <!-- Local odometry EKF: wheel encoder odometry + IMU. -->
    <node pkg="robot_localization" type="ekf_localization_node" name="ekf_se_odom" clear_params="true" output="screen" />

    <!-- Global map EKF: wheel encoder odometry + GPS odometry + IMU. -->
    <node pkg="robot_localization" type="ekf_localization_node" name="ekf_se_map" clear_params="true" output="screen">
      <remap from="odometry/filtered" to="odometry/filtered_map" />
    </node>

    <!-- Give simulated GPS a realistic covariance before it is fused globally. -->
    <node pkg="outdoor_waypoint_nav" type="gps_covariance_relay.py" name="gps_covariance_relay" output="screen">
      <param name="input_topic" value="/gps/fix" />
      <param name="output_topic" value="/outdoor_waypoint_nav/gps/fix_with_covariance" />
      <rosparam param="position_diag">[1.0, 1.0, 4.0]</rosparam>
    </node>

    <!-- Match the outdoor stack: navsat_transform works in the global map frame. -->
    <node pkg="robot_localization" type="navsat_transform_node" name="navsat_transform" clear_params="true" output="screen">
      <remap from="odometry/filtered" to="odometry/filtered_map"/>
      <remap from="gps/fix" to="/outdoor_waypoint_nav/gps/fix_with_covariance"/>
      <remap from="imu/data" to="/imu/data"/>
    </node>
  </group>

</launch>
