<?xml version="1.0"?>

<launch>

  <!--
    Sim waypoint control:
    - uses the existing points_sim.txt directly
    - shows waypoint markers in RViz immediately
    - keeps the same keyboard/joy flow for pressing RB to start following
  -->
  <arg name="collect_button_num" value="4" />
  <arg name="collect_button_sym" value="LB" />
  <arg name="send_button_num" value="5" />
  <arg name="send_button_sym" value="RB" />
  <arg name="calibrate_button_num" value="7" />
  <arg name="calibrate_button_sym" value="START" />
  <arg name="abort_button_num" value="1" />
  <arg name="abort_button_sym" value="B" />
  <arg name="continue_button_num" value="3" />
  <arg name="continue_button_sym" value="Y" />

  <arg name="simulation_enabled" value="true" />
  <arg name="coordinates_file_dir" value="/waypoint_files/points_sim.txt" />
  <arg name="waypoint_marker_frame" value="map" />
  <arg name="waypoint_marker_topic" value="/outdoor_waypoint_nav/collected_waypoints" />
  <arg name="waypoint_marker_scale" value="0.7" />

  <param name="/outdoor_waypoint_nav/coordinates_file" value="$(arg coordinates_file_dir)" type="string" />
  <param name="/outdoor_waypoint_nav/collect_button_num" value="$(arg collect_button_num)" type="int" />
  <param name="/outdoor_waypoint_nav/collect_button_sym" value="$(arg collect_button_sym)" type="string" />
  <param name="/outdoor_waypoint_nav/send_button_num" value="$(arg send_button_num)" type="int" />
  <param name="/outdoor_waypoint_nav/send_button_sym" value="$(arg send_button_sym)" type="string" />
  <param name="/outdoor_waypoint_nav/calibrate_button_num" value="$(arg calibrate_button_num)" type="int" />
  <param name="/outdoor_waypoint_nav/calibrate_button_sym" value="$(arg calibrate_button_sym)" type="string" />
  <param name="/outdoor_waypoint_nav/abort_button_num" value="$(arg abort_button_num)" type="int" />
  <param name="/outdoor_waypoint_nav/abort_button_sym" value="$(arg abort_button_sym)" type="string" />
  <param name="/outdoor_waypoint_nav/continue_button_num" value="$(arg continue_button_num)" type="int" />
  <param name="/outdoor_waypoint_nav/continue_button_sym" value="$(arg continue_button_sym)" type="string" />
  <param name="/outdoor_waypoint_nav/sim_enabled" value="$(arg simulation_enabled)" type="bool" />
  <param name="/outdoor_waypoint_nav/waypoint_marker_frame" value="$(arg waypoint_marker_frame)" type="string" />
  <param name="/outdoor_waypoint_nav/waypoint_marker_topic" value="$(arg waypoint_marker_topic)" type="string" />
  <param name="/outdoor_waypoint_nav/waypoint_marker_scale" value="$(arg waypoint_marker_scale)" type="double" />

  <include file="$(find outdoor_waypoint_nav)/launch/simulation/keyboard_to_joy.launch" />

  <node ns="/outdoor_waypoint_nav"
        pkg="outdoor_waypoint_nav"
        type="joy_launch_control.py"
        name="joy_launch_control"
        output="screen" />

  <node ns="/outdoor_waypoint_nav"
        pkg="outdoor_waypoint_nav"
        type="publish_waypoints_from_file"
        name="publish_waypoints_from_file"
        output="screen" />

</launch>
