<?xml version="1.0"?>
<launch>
  <param name="use_sim_time" value="false"/>

  <!-- Remove this if base_link -> imu_link is already published elsewhere. -->
  <node pkg="tf2_ros"
        type="static_transform_publisher"
        name="base_link_to_imu"
        args="0 0 0 0 0 0 base_link imu_link" />

  <node pkg="robot_localization"
        type="ekf_localization_node"
        name="ekf_se_odom"
        output="screen"
        clear_params="true">
    <remap from="odometry/filtered" to="odometry/filtered"/>
    <rosparam command="load" file="$(find robot_localization)/params/ekf_se_odom.yaml" />
  </node>

  <node pkg="robot_localization"
        type="ekf_odom_yaw_logger.py"
        name="ekf_odom_yaw_logger"
        output="screen">
    <remap from="odometry/filtered" to="/odometry/filtered"/>
    <param name="log_rate_hz" value="10.0"/>
  </node>
</launch>
