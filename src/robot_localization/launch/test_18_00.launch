<?xml version="1.0"?>
<launch>

    <!-- RViz -->
    <arg name="rviz" default="true"/>
    <arg name="config" default="default" />

    <node pkg="move_base" type="move_base" name="move_base" output="screen">

        <!-- planner -->
        <param name="base_global_planner" value="global_planner/GlobalPlanner"/>
        <param name="base_local_planner" value="dwa_local_planner/DWAPlannerROS"/>

        <!-- GLOBAL COSTMAP -->
        <rosparam param="global_costmap">
            global_frame: map
            robot_base_frame: base_link
            update_frequency: 1.0
            publish_frequency: 1.0
            rolling_window: true
            width: 100.0
            height: 100.0
            resolution: 0.5
            static_map: false
            plugins:
                - {name: inflation_layer, type: "costmap_2d::InflationLayer"}
            inflation_layer:
                inflation_radius: 0.5
        </rosparam>


        <!-- LOCAL COSTMAP -->
        <rosparam param="local_costmap">
            global_frame: map
            robot_base_frame: base_link
            rolling_window: true
            width: 20.0
            height: 20.0
            resolution: 0.2
            update_frequency: 5.0
            publish_frequency: 2.0
            static_map: false

            plugins:
                - {name: inflation_layer, type: "costmap_2d::InflationLayer"}

            inflation_layer:
                inflation_radius: 0.5
        </rosparam>

        <rosparam param="DWAPlannerROS">
            max_vel_x: 0.5
            min_vel_x: 0.0
            max_vel_trans: 3.0
            min_vel_trans: 0.05
            max_vel_theta: 1.0
            min_vel_theta: 0.0
            acc_lim_x: 2.0
            acc_lim_theta: 1.5
            xy_goal_tolerance: 2.0
            yaw_goal_tolerance: 3.14
            sim_time: 3.0
        </rosparam>
        <rosparam param="move_base">
            transform_tolerance: 0.5
            controller_frequency: 10.0
            oscillation_timeout: 10.0
            oscillation_distance: 0.5
        </rosparam>
        <remap from="odom" to="/warthog_velocity_controller/odom"/>

    </node>

    <!-- RViz -->
    <node if="$(arg rviz)" pkg="rviz" type="rviz" name="$(anon rviz)" respawn="false" 
        output="screen" args="-d $(find warthog_simulation)/rviz/$(arg config).rviz" />
</launch>