  <!-- ===================== GPS WAYPOINT SENDER ===================== -->
  <!-- <node pkg="robot_localization"
        type="send_waypoint"
        name="send_waypoint"
        output="screen"
        launch-prefix="bash -c 'sleep 3; $0 $@'" /> -->

  <include file="$(find warthog_slam)/launch/amcl.launch" />

  <!-- ===================== RVIZ ===================== -->
  <node if="$(arg rviz)"
        pkg="rviz"
        type="rviz"
        name="$(anon rviz)"
        output="screen"
        args="-d $(find warthog_simulation)/rviz/$(arg config).rviz" />

</launch>